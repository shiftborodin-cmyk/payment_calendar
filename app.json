{
  "expo": {
    "name": "Payment Calendar",
    "slug": "payment-calendar",
    "version": "0.1.3",
    "icon": "./assets/payment-calendar-icon.png",
    "orientation": "portrait",
    "scheme": "paymentcalendar",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.personal.paymentcalendar"
    },
    "android": {
      "package": "com.personal.paymentcalendar",
      "adaptiveIcon": {
        "backgroundColor": "#0B1410",
        "foregroundImage": "./assets/payment-calendar-icon.png"
      }
    },
    "plugins": [
      "expo-router",
      "expo-notifications"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "f40c79ca-248e-462c-98be-99260834e306"
      }
    }
  }
}
